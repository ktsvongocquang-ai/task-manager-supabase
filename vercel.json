{
    "crons": [
        {
            "path": "/api/generate-grok-news",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/generate-grok-news?job=zalo",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/generate-grok-news?job=zalo",
            "schedule": "35 6 * * *"
        },
        {
            "path": "/api/generate-grok-news?job=zalo",
            "schedule": "30 10 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ]
}
